{
  "name": "speakeasy-be",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "services/*",
    "gateway",
    "packages/*"
  ],
  "scripts": {
    "dev:auth": "npm run dev --workspace=@speakeasy/auth --",
    "ts:check": "npm run ts:check --workspaces --if-present",
    "lint:check": "npm run lint:check --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
